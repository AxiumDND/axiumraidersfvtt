{
  "id": "axiumraidersfvtt",
  "title": "Axium's Raiders of the Serpent Sea",
  "description": "Enhanced content for Raiders of the Serpent Seas including maps, tokens, and Theatre of the Mind scenes. Compatible with Foundry VTT v11 through v14, with advanced tile functionality powered by Monk's Active Tile Triggers.",
  "version": "14.0.1",
  "minimumCoreVersion": "11",
  "compatibleCoreVersion": "14",
  "compatibility": {
    "minimum": "11",
    "verified": "14",
    "maximum": "14"
  },
  "authors": [
    {
      "name": "Axium",
      "discord": "Axium"
    }
  ],
  "relationships": {
    "recommends": [
      {
        "id": "monks-active-tiles",
        "type": "module",
        "manifest": "https://github.com/ironmonk88/monks-active-tiles/releases/latest/download/module.json",
        "reason": "Required for interactive tile automations used throughout the adventure scenes."
      },
      {
        "id": "tagger",
        "type": "module",
        "reason": "Used by Monk's Active Tiles for tag-based tile triggers."
      },
      {
        "id": "JB2A_DnD5e",
        "type": "module",
        "reason": "Provides the visual effects referenced by scenes and macros."
      },
      {
        "id": "tile-scroll",
        "type": "module",
        "reason": "Enables scrolling Theatre of the Mind tile backgrounds."
      }
    ]
  },
