# Backup folders
backup/
backup/*
temp_backup/

# Node.js dependencies
node_modules/

# Temporary unpacked compendium output
tmp-unpacked/

# Stray LevelDB files outside packs/ (e.g. accidentally dropped at repo root)
*.log
*.ldb
MANIFEST-*
CURRENT
LOG
LOG.old
# But ALWAYS track LevelDB files inside the compendium packs.
# (Order matters: negations must follow the broad ignores above.)
!packs/**/*.log
!packs/**/*.ldb
!packs/**/MANIFEST-*
!packs/**/CURRENT
!packs/**/LOG
!packs/**/LOG.old

# System files
.DS_Store
Thumbs.db

# Module distribution files
*.zip

# Common large file types
*.mp4
*.webm
*.wav
*.mp3
*.psd
*.psb
*.xcf

# System and IDE files
.idea/
.vscode/

# AI Information folder
AI_INFO/ 